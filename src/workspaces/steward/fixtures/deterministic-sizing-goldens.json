{
  "cases": [
    {
      "name": "single target reaches requested maximum",
      "account": {
        "equity": "10000",
        "positionQuantity": "0",
        "markPrice": "100",
        "quantityIncrement": "1"
      },
      "caps": {
        "maxPositionPctOfEquity": "25",
        "maxSingleOrderPctOfEquity": "20",
        "remainingLossPctOfEquity": "5"
      },
      "capabilities": {
        "market": true,
        "stop": true,
        "stopLimit": { "supported": true, "limitOffsetBps": 25 }
      },
      "expected": {
        "kind": "proposal",
        "quantity": "15",
        "protectionOrderType": "STP"
      }
    },
    {
      "name": "single-order ceiling clips to target minimum",
      "account": {
        "equity": "10000",
        "positionQuantity": "0",
        "markPrice": "100",
        "quantityIncrement": "1"
      },
      "caps": {
        "maxPositionPctOfEquity": "25",
        "maxSingleOrderPctOfEquity": "10",
        "remainingLossPctOfEquity": "5"
      },
      "capabilities": {
        "market": true,
        "stop": true,
        "stopLimit": { "supported": false }
      },
      "expected": {
        "kind": "clipped",
        "quantity": "10",
        "protectionOrderType": "STP"
      }
    },
    {
      "name": "explicit stop-limit offset is deterministic",
      "account": {
        "equity": "10000",
        "positionQuantity": "0",
        "markPrice": "100",
        "quantityIncrement": "1"
      },
      "caps": {
        "maxPositionPctOfEquity": "25",
        "maxSingleOrderPctOfEquity": "20",
        "remainingLossPctOfEquity": "5"
      },
      "capabilities": {
        "market": true,
        "stop": false,
        "stopLimit": { "supported": true, "limitOffsetBps": 25 }
      },
      "expected": {
        "kind": "proposal",
        "quantity": "15",
        "protectionOrderType": "STP_LMT",
        "limitPrice": "93.9645"
      }
    },
    {
